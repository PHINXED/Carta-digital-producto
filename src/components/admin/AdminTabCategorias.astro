<div id="tab-categorias" class="tab-content">
  <section class="admin-page admin-page--split">
    <aside class="admin-page__sidebar">
      <div class="form-box admin-sticky-card">
        <div class="panel-heading panel-heading--stack">
          <div>
            <h2 id="categoria-form-title">Nueva categoria</h2>
            <p>Crea categorias y organiza visualmente sus subcategorias.</p>
          </div>
        </div>

        <input type="hidden" id="editCategoriaId" />

        <div class="form-stack">
          <div class="field">
            <label for="categoriaNombre">Nombre de la categoria</label>
            <input id="categoriaNombre" placeholder="Nombre de categoria" />
          </div>

          <div
            id="categoriaSubcategoriasEditor"
            class="category-subeditor"
            style="display: none"
          >
            <div class="category-subeditor__head">
              <div>
                <h3>Subcategorias</h3>
                <p>
                  Las que crees aqui apareceran luego al seleccionar esta
                  categoria en un plato.
                </p>
              </div>
            </div>

            <div class="category-subeditor__create">
              <input
                id="categoriaSubcategoriaNombre"
                placeholder="Nueva subcategoria"
              />
              <button
                id="addCategoriaSubcategoriaBtn"
                type="button"
                class="secondaryBtn"
              >
                Anadir
              </button>
            </div>

            <div
              id="categoriaSubcategoriasList"
              class="category-subeditor__list"
            ></div>
          </div>
        </div>

        <div class="form-actions">
          <button id="guardarCategoriaBtn" type="button">Guardar categoria</button>
          <button
            class="cancel"
            id="cancelCategoriaBtn"
            type="button"
            style="display: none"
          >
            Cancelar
          </button>
        </div>
      </div>
    </aside>

    <div class="admin-page__main">
      <div class="content-card list-panel">
        <div class="panel-heading panel-heading--stack">
          <div>
            <h2>Categorias registradas</h2>
            <p>
              Cada tarjeta resume las categorias activas y las subcategorias
              creadas para usarlas despues en tus platos.
            </p>
          </div>
        </div>

        <div id="categoriasContainer" class="category-list"></div>
      </div>
    </div>
  </section>
</div>
