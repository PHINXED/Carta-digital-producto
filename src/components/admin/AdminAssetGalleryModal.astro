<div
  id="assetGalleryModal"
  class="imodal"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-labelledby="assetGalleryTitle"
>
  <button
    type="button"
    class="imodal-backdrop"
    data-asset-gallery-close
    aria-label="Cerrar galeria"
  ></button>

  <div class="imodal-card asset-gallery-modal-card">
    <div class="imodal-header">
      <h3 id="assetGalleryTitle">Galeria de imagenes</h3>
      <button
        id="assetGalleryCloseBtn"
        type="button"
        class="imodal-close secondaryBtn"
        aria-label="Cerrar galeria"
      >
        <span class="material-symbols-outlined" aria-hidden="true">close</span>
      </button>
    </div>

    <p id="assetGallerySubtitle" class="form-subtitle">
      Selecciona, sube o elimina imagenes del almacenamiento.
    </p>

    <div class="asset-gallery-toolbar">
      <input id="assetGalleryUploadInput" type="file" accept="image/*" class="ical-file-input" />
      <button id="assetGalleryUploadBtn" type="button">Subir imagen</button>
      <button id="assetGalleryRefreshBtn" type="button" class="secondaryBtn">Actualizar</button>
    </div>

    <p id="assetGalleryStatus" class="muted asset-gallery-status" aria-live="polite"></p>
    <div id="assetGalleryGrid" class="asset-gallery-grid"></div>
  </div>
</div>
