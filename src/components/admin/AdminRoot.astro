---
import AdminLogin from './AdminLogin.astro';
import AdminTabPerfil from './AdminTabPerfil.astro';
import AdminTabCategorias from './AdminTabCategorias.astro';
import AdminTabCatalogo from './AdminTabCatalogo.astro';
import AdminTabMenus from './AdminTabMenus.astro';
import AdminAssetGalleryModal from './AdminAssetGalleryModal.astro';
import "../../styles/styles-admin-origin.css";
import adminScriptUrl from "../../scripts/admin-crm.js?url";
---

<section class="imenu-admin">
  <div class="imenu-admin-shell">
    <header class="imenu-admin-intro">
      <p class="imenu-admin-kicker">Multi Servicio</p>
      <h1 class="imenu-admin-title">CartaDigitalLM</h1>
      <p class="imenu-admin-subtitle">
        Gestiona perfil, categorias y catalogo de platos.
      </p>
    </header>

    <AdminLogin />

    <div id="admin-panel" style="display: none">
      <div class="tabs" role="tablist" aria-label="Pestañas de CartaDigitalLM">
        <button class="tab active" data-tab="perfil" type="button">
          <span class="material-symbols-outlined tab-icon" aria-hidden="true">storefront</span>
          <span>Perfil</span>
        </button>
        <button class="tab" data-tab="categorias" type="button">
          <svg class="tab-svg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" aria-hidden="true">
            <path
              fill="currentColor"
              d="M14 25h14v2H14zm-6.83 1l-2.58 2.58L6 30l4-4l-4-4l-1.42 1.41zM14 15h14v2H14zm-6.83 1l-2.58 2.58L6 20l4-4l-4-4l-1.42 1.41zM14 5h14v2H14zM7.17 6L4.59 8.58L6 10l4-4l-4-4l-1.42 1.41z"
            />
          </svg>
          <span>Categorias</span>
        </button>
        <button class="tab" data-tab="catalogo" type="button">
          <span class="material-symbols-outlined tab-icon" aria-hidden="true">restaurant_menu</span>
          <span>Catalogo (Platos)</span>
        </button>
        <button class="tab" data-tab="menus" type="button">
          <svg class="tab-svg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M6 22q-.825 0-1.412-.587T4 20v-2q-.425 0-.712-.288T3 17q0-.4.363-.562T4 16v-3q-.425 0-.712-.288T3 12q0-.4.363-.562T4 11V8q-.425 0-.712-.288T3 7q0-.4.363-.562T4 6V4q0-.825.588-1.412T6 2h12q.825 0 1.413.588T20 4v16q0 .825-.587 1.413T18 22zm3.5-9v3.25q0 .325.213.538t.537.212t.538-.213t.212-.537V13q.65-.175 1.075-.712t.425-1.213V7.5q0-.2-.15-.35T12 7t-.35.15t-.15.35v3.275h-.75V7.5q0-.2-.15-.35T10.25 7t-.35.15t-.15.35v3.275H9V7.5q0-.2-.15-.35T8.5 7t-.35.15T8 7.5v3.575q0 .675.425 1.213T9.5 13m5.5 0v3.25q0 .325.213.538t.537.212t.538-.213t.212-.537V7.575q0-.275-.187-.425T15.825 7q-.325 0-.712.175t-.738.525q-.425.425-.65.963T13.5 9.825V12q0 .425.288.713T14.5 13z"
            />
          </svg>
          <span>Menus</span>
        </button>
      </div>

      <div id="adminInlineNotice" class="admin-inline-notice" aria-live="polite" aria-atomic="true"></div>

      <AdminTabPerfil />
      <AdminTabCategorias />
      <AdminTabCatalogo />
      <AdminTabMenus />
      <AdminAssetGalleryModal />

      <button id="logoutBtn" type="button">Cerrar sesion</button>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>

  <script type="module" src={adminScriptUrl}></script>
</section>
