<div id="tab-perfil" class="tab-content active">
  <section class="admin-page admin-page--profile">
    <div class="form-box profile-shell">
      <div class="panel-heading panel-heading--stack">
        <div>
          <h2>Perfil del local</h2>
          <p>Ajustes visuales, enlaces publicos y branding del menu.</p>
        </div>
      </div>

      <section class="form-section profile-block">
        <div class="section-header section-header--stack">
          <div>
            <h4>Identificadores iServices</h4>
            <p class="section-hint">URL publica del menu</p>
          </div>
        </div>

        <div class="section-body">
          <div class="profile-link-row">
            <input id="perfilSlugUrl" readonly placeholder="https://..." />
            <button type="button" id="perfilSlugCopyBtn" class="secondaryBtn">
              Copiar
            </button>
            <button type="button" id="perfilSlugOpenBtn" class="secondaryBtn">
              Abrir
            </button>
          </div>

          <div class="grid-2 profile-meta-grid">
            <div class="field">
              <label>Slug</label>
              <input id="perfilSlug" readonly placeholder="-" />
            </div>
            <div class="field">
              <label>UID del cliente</label>
              <input id="perfilUid" readonly placeholder="-" />
            </div>
          </div>
        </div>
      </section>

      <section class="form-section profile-block">
        <div class="section-header section-header--stack">
          <div>
            <h4>Datos del negocio</h4>
            <p class="section-hint">
              Informacion general del local, reseñas y acceso WiFi.
            </p>
          </div>
        </div>

        <div class="section-body">
          <div class="grid-2">
            <div class="field">
              <label>Nombre</label>
              <input id="perfilNombre" placeholder="Nombre del local" />
            </div>
            <div class="field">
              <label>Telefono</label>
              <input id="perfilTelefono" placeholder="+34 000 000 000" />
            </div>
          </div>

          <div class="grid-2">
            <div class="field">
              <label>Direccion</label>
              <input id="perfilDireccion" placeholder="Calle, numero, ciudad" />
            </div>
            <div class="field">
              <label>URL de resenas</label>
              <input id="perfilReviews" placeholder="https://..." />
            </div>
          </div>

          <div class="grid-2">
            <div class="field">
              <label>Google Place ID</label>
              <div class="inline-actions">
                <input id="perfilGooglePlaceId" placeholder="ChIJ..." />
                <button type="button" id="buscarPlaceIdBtn" class="secondaryBtn">
                  Buscar Place ID
                </button>
              </div>
            </div>
            <div class="field">
              <label>WiFi (nombre de red)</label>
              <input id="perfilWifi" placeholder="Nombre de la red" />
            </div>
          </div>

          <div class="grid-2">
            <div class="field">
              <label>WiFi (clave)</label>
              <input
                id="perfilWifiPass"
                type="text"
                placeholder="Clave privada"
                autocomplete="new-password"
              />
              <small class="hint">
                La clave no se expone automaticamente en la carta.
              </small>
            </div>

            <div class="field">
              <label>WiFi (PIN de acceso)</label>
              <div class="password-field">
                <input
                  id="perfilWifiPin"
                  type="password"
                  inputmode="numeric"
                  autocomplete="new-password"
                  placeholder="PIN de 4 a 8 digitos"
                />
                <button
                  type="button"
                  id="perfilWifiPinToggleBtn"
                  class="icon-ghost-btn"
                  aria-label="Mostrar PIN"
                >
                  Ver
                </button>
              </div>
              <small class="hint">
                Si escribes uno nuevo, sustituira al PIN anterior al guardar.
              </small>
            </div>
          </div>
        </div>
      </section>

      <section class="form-section profile-block">
        <div class="section-header section-header--stack">
          <div>
            <h4>Portada y platos</h4>
            <p class="section-hint">
              Portada principal, logo y foto por defecto para platos.
            </p>
          </div>
        </div>

        <div class="section-body profile-media-grid">
          <article class="profile-media-card">
            <div class="profile-media-card__header">
              <div>
                <h5>Portada</h5>
                <p>Hero principal del menu publico</p>
              </div>
            </div>

            <input
              id="perfilPortadaUrl"
              placeholder="Imagen seleccionada"
              readonly
            />

            <div class="profile-media-card__actions">
              <button
                type="button"
                class="secondaryBtn"
                id="perfilPortadaGaleriaBtn"
              >
                Galeria de imagenes
              </button>
              <button type="button" class="cancel" id="perfilPortadaClearBtn">
                Quitar
              </button>
            </div>

            <input id="perfilPortadaFile" type="file" accept="image/*" />
            <div
              id="perfilPortadaPreview"
              class="image-preview image-preview--media"
              style="display: none"
            ></div>
          </article>

          <article class="profile-media-card">
            <div class="profile-media-card__header">
              <div>
                <h5>Logo</h5>
                <p>Emblema o simbolo superpuesto</p>
              </div>
            </div>

            <input id="perfilLogoUrl" placeholder="Imagen seleccionada" readonly />

            <div class="profile-media-card__actions">
              <button
                type="button"
                class="secondaryBtn"
                id="perfilLogoGaleriaBtn"
              >
                Galeria de imagenes
              </button>
              <button type="button" class="cancel" id="perfilLogoClearBtn">
                Quitar
              </button>
            </div>

            <input id="perfilLogoFile" type="file" accept="image/*" />
            <div
              id="perfilLogoPreview"
              class="image-preview image-preview--media"
              style="display: none"
            ></div>
          </article>

          <article class="profile-media-card">
            <div class="profile-media-card__header">
              <div>
                <h5>Imagen por defecto de platos</h5>
                <p>Se usa cuando un plato no tiene foto propia</p>
              </div>
            </div>

            <input
              id="perfilPlatoDefaultUrl"
              placeholder="Imagen seleccionada"
              readonly
            />

            <div class="profile-media-card__actions">
              <button
                type="button"
                class="secondaryBtn"
                id="perfilPlatoDefaultGaleriaBtn"
              >
                Galeria de imagenes
              </button>
              <button
                type="button"
                class="cancel"
                id="perfilPlatoDefaultClearBtn"
              >
                Quitar
              </button>
            </div>

            <input id="perfilPlatoDefaultFile" type="file" accept="image/*" />
            <div
              id="perfilPlatoDefaultPreview"
              class="image-preview image-preview--media"
              style="display: none"
            ></div>
          </article>
        </div>
      </section>

      <section class="form-section profile-block">
        <div class="section-header section-header--stack">
          <div>
            <h4>Apariencia del menu publico</h4>
            <p class="section-hint">
              Color principal aplicado al admin y al menu publico.
            </p>
          </div>
        </div>

        <div class="section-body">
          <div class="theme-preview" aria-hidden="true">
            <div class="theme-preview__top"></div>
            <div class="theme-preview__content">
              <span class="theme-preview__badge">Vista previa</span>
              <span class="theme-preview__line"></span>
              <span class="theme-preview__line theme-preview__line--short"></span>
            </div>
          </div>

          <div class="appearance-grid">
            <div class="field appearance-grid__picker">
              <label>Color del menu</label>
              <div class="color-picker-row">
                <input id="perfilColorPrincipal" type="color" value="#ffe800" />
                <span id="perfilColorPrincipalLabel">#FFE800</span>
              </div>
              <small class="hint">
                Selecciona directamente el color exacto que quieres aplicar.
              </small>
            </div>

            <div class="field appearance-grid__picker">
              <label for="perfilLogoBgMode">Fondo del logo</label>
              <select id="perfilLogoBgMode">
                <option value="solid">Color</option>
                <option value="transparent">Transparente</option>
              </select>

              <div class="logo-bg-controls" id="perfilLogoBgControls">
                <div class="logo-bg-row">
                  <label for="perfilLogoBgColor">Color de fondo</label>
                  <input id="perfilLogoBgColor" type="color" value="#ffffff" />
                </div>

                <div class="logo-bg-row logo-bg-row--range">
                  <label for="perfilLogoBgOpacity">
                    Opacidad
                    <span id="perfilLogoBgOpacityLabel">82%</span>
                  </label>
                  <input
                    id="perfilLogoBgOpacity"
                    type="range"
                    min="0"
                    max="100"
                    step="1"
                    value="82"
                  />
                </div>
              </div>

              <small class="hint">
                Elige transparente o un color de fondo para el logo con la opacidad que quieras.
              </small>
            </div>
          </div>
        </div>
      </section>

      <div class="form-actions profile-actions">
        <button id="guardarPerfilBtn" type="button">Guardar perfil</button>
      </div>
    </div>
  </section>

  <div id="profileImageGalleryModal" class="imodal" aria-hidden="true">
    <button
      type="button"
      class="imodal-backdrop"
      id="profileImageGalleryBackdrop"
      aria-label="Cerrar"
    ></button>
    <div
      class="imodal-card imodal-card--gallery"
      role="dialog"
      aria-modal="true"
      aria-label="Galeria de imagenes"
    >
      <div class="imodal-header">
        <h3 id="profileImageGalleryTitle" style="margin: 0">Mis imagenes</h3>
        <button
          type="button"
          class="imodal-close"
          id="profileImageGalleryClose"
          aria-label="Cerrar"
        >
          X
        </button>
      </div>

      <p class="hint" style="margin-top: 8px">
        Selecciona una imagen para usarla aqui o borra la que ya no necesites.
      </p>

      <div class="plato-gallery-toolbar">
        <button type="button" class="secondaryBtn" id="profileImageGalleryRefresh">
          Actualizar
        </button>
      </div>
      <div id="profileImageGalleryGrid" class="plato-gallery-grid"></div>
    </div>
  </div>
</div>
